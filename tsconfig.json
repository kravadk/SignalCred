{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next-build-check/types/**/*.ts",
    ".next-dev-check/types/**/*.ts",
    ".next-dev-square-fix/types/**/*.ts",
    ".next-build-focused/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "_cipherpay_analysis",
    "_cofhepoker_analysis",
    "_shadowdao_analysis"
  ]
}
