# Bags
BAGS_API_KEY=
BAGS_PARTNER_KEY=
BAGS_PARTNER_CONFIG=

# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
PRIVATE_KEY=

# Birdeye
BIRDEYE_API_KEY=

# Database (Neon)
DATABASE_URL=postgresql://...

# Auth (Privy)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# AI
ANTHROPIC_API_KEY=

# Tether QVAC private review service
# QVAC_MOCK=true enables inline demo mode on Vercel — no companion needed
# Set QVAC_SERVICE_URL when running npm run qvac:companion for real local inference
QVAC_SERVICE_URL=
QVAC_COMPANION_URL=http://127.0.0.1:8787
QVAC_ENABLED=true
QVAC_PORT=8787
QVAC_MOCK=true
QVAC_LLM_MODEL_SRC=
QVAC_LLM_MODEL_TYPE=llm
QVAC_LLM_CTX_SIZE=4096
QVAC_EMBED_MODEL_SRC=
QVAC_EMBED_MODEL_TYPE=embeddings
QVAC_TRANSLATION_MODEL_SRC=
QVAC_TRANSLATION_MODEL_TYPE=nmt
QVAC_REQUIRE_REAL=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_AGENTATION=false
NEXT_PUBLIC_AGENTATION_ENDPOINT=http://localhost:4747

# Automations
AUTOMATION_SECRET=

# ReStream worker
# RESTREAM_INGEST_URL should point to the Next.js API route in production:
# https://your-domain.com/api/bags/restream/ingest
RESTREAM_INGEST_URL=http://localhost:3000/api/bags/restream/ingest
RESTREAM_INGEST_SECRET=
BAGS_RESTREAM_URL=wss://restream.bags.fm
BAGS_RESTREAM_WORKER_URL=

# GitHub Actions / production monitoring
# Add these as GitHub repository secrets, not as public client env:
# SIGNALCRED_URL=https://your-production-domain.com
# AUTOMATION_SECRET=must-match-your-production-app-secret
